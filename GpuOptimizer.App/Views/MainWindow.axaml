<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GpuOptimizer.App.ViewModels"
        xmlns:loc="using:GpuOptimizer.App.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="GpuOptimizer.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1120"
        Height="720"
        MinWidth="960"
        MinHeight="600"
        Title="{DynamicResource AppTitle}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="16">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{DynamicResource AppTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextBrush}" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Top">
                <TextBlock Text="{DynamicResource ThemeLabel}"
                           FontSize="11"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource LanguageLabel}"
                           FontSize="11"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          Width="108"
                          Height="28">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="loc:LanguageOption">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource AppInfoBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10 8"
                Margin="0 10 0 0"
                Background="{DynamicResource AppInfoBackgroundBrush}">
            <TextBlock Text="{DynamicResource InfoText}"
                       FontSize="11"
                       Foreground="{DynamicResource AppInfoTextBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0 12 0 0">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button Content="{DynamicResource RefreshButton}"
                        MinWidth="78"
                        Height="30"
                        Padding="12 1 12 3"
                        VerticalContentAlignment="Center"
                        Command="{Binding RefreshCommand}" />
                <Button Content="{DynamicResource SelectAllButton}"
                        MinWidth="86"
                        Height="30"
                        Padding="12 1 12 3"
                        VerticalContentAlignment="Center"
                        Command="{Binding SelectAllOptimizableCommand}" />
                <Button Content="{DynamicResource OptimizeButton}"
                        MinWidth="88"
                        Height="30"
                        Padding="12 1 12 3"
                        VerticalContentAlignment="Center"
                        Background="#2563EB"
                        Foreground="White"
                        Command="{Binding OptimizeSelectedCommand}" />
                <Button Content="{DynamicResource RestoreButton}"
                        MinWidth="82"
                        Height="30"
                        Padding="12 1 12 3"
                        VerticalContentAlignment="Center"
                        Command="{Binding RestoreSelectedCommand}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding DisplayTotalProcesses}"
                           FontSize="12"
                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                <TextBlock Text="·" FontSize="12" Foreground="{DynamicResource AppSeparatorTextBrush}" />
                <TextBlock Text="{Binding DisplaySelectedProcesses}"
                           FontSize="12"
                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                <TextBlock Text="·" FontSize="12" Foreground="{DynamicResource AppSeparatorTextBrush}" />
                <TextBlock Text="{Binding DisplayOptimizableProcesses}"
                           FontSize="12"
                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                <TextBlock Text="·" FontSize="12" Foreground="{DynamicResource AppSeparatorTextBrush}" />
                <TextBlock Text="{Binding DisplaySelectedSaving}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#EA580C" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="3"
                BorderBrush="{DynamicResource AppPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10 8"
                Margin="0 10 0 0"
                Background="{DynamicResource AppPanelBackgroundBrush}">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource GpuMemoryLabel}"
                           FontSize="11"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="0 0 14 0" />
                <ItemsControl Grid.Column="1" ItemsSource="{Binding GpuMemorySummaries}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GpuMemorySummaryViewModel">
                            <Border BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="0"
                                    Background="{Binding BackgroundBrush}">
                                <Grid ColumnDefinitions="4,Auto,Auto">
                                    <Border Grid.Column="0"
                                            Width="4"
                                            Background="{Binding AccentBrush}"
                                            CornerRadius="4 0 0 4" />
                                    <StackPanel Grid.Column="1"
                                                Spacing="1"
                                                Margin="8 4 0 4">
                                        <TextBlock Text="{Binding GpuName}"
                                                   FontSize="11"
                                                   MaxWidth="260"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding KindLabel}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DisplayMemory}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding AccentBrush}"
                                               Margin="12 0 8 0"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <DataGrid x:Name="ProcessGrid"
                  Grid.Row="4"
                  ItemsSource="{Binding Processes}"
                  AutoGenerateColumns="False"
                  SelectionMode="Extended"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  IsReadOnly="False"
                  FontSize="12"
                  GridLinesVisibility="Vertical"
                  HeadersVisibility="Column"
                  RowHeight="26"
                  HorizontalAlignment="Stretch"
                  Margin="0 10 0 0"
                  BorderThickness="1"
                  CornerRadius="0 0 6 6"
                  DoubleTapped="ProcessGrid_DoubleTapped">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{DynamicResource SelectHeader}" Width="72" MinWidth="54">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      IsEnabled="{Binding IsOptimizable}"
                                      HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{DynamicResource ProcessNameHeader}" Width="2.2*" MinWidth="120" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ProcessName}"
                                       Margin="18 0 0 0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding ProcessDetailsTooltip}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{DynamicResource GpuHeader}" Width="220" MinWidth="140" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding GpuBadges}" Margin="18 0 0 0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GpuBadgeViewModel">
                                        <Border BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="6 1"
                                                Background="{Binding BackgroundBrush}"
                                                ToolTip.Tip="{Binding GpuName}">
                                            <TextBlock Text="{Binding GpuName}"
                                                       FontSize="11"
                                                       Foreground="{Binding AccentBrush}"
                                                       MaxWidth="190"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource MemoryHeader}" Binding="{Binding DedicatedMemoryMb, StringFormat={}{0:F1}}" Width="95" MinWidth="78" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource PreferenceHeader}" Binding="{Binding CurrentPreference}" Width="110" MinWidth="96" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

    </Grid>

</Window>
