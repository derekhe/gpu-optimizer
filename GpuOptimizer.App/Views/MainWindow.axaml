<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GpuOptimizer.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="GpuOptimizer.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1120"
        Height="720"
        MinWidth="960"
        MinHeight="600"
        Title="GPU Optimizer">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16">
        <Border Grid.Row="0"
                BorderBrush="#D9DCE1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
            <StackPanel Spacing="4">
                <TextBlock Text="GPU Optimizer"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1F2937" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="#4B5563"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0 10 0 0">
            <Button Content="Refresh"
                    Width="90"
                    Height="30"
                    Command="{Binding RefreshCommand}" />
            <Button Content="Select"
                    Width="84"
                    Height="30"
                    Command="{Binding SelectAllOptimizableCommand}" />
            <Button Content="Optimize"
                    Width="92"
                    Height="30"
                    Command="{Binding OptimizeSelectedCommand}" />
            <Button Content="Restore"
                    Width="92"
                    Height="30"
                    Command="{Binding RestoreSelectedCommand}" />
        </StackPanel>

        <UniformGrid Grid.Row="2"
                     Columns="4"
                     Margin="0 10 0 0"
                     HorizontalAlignment="Stretch">
            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0 0 8 0">
                <StackPanel Spacing="2">
                    <TextBlock Text="Total" FontSize="11" Foreground="#6B7280" />
                    <TextBlock Text="{Binding TotalProcessCount}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0 0 8 0">
                <StackPanel Spacing="2">
                    <TextBlock Text="Selected" FontSize="11" Foreground="#6B7280" />
                    <TextBlock Text="{Binding SelectedProcessCount}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0 0 8 0">
                <StackPanel Spacing="2">
                    <TextBlock Text="Optimizable" FontSize="11" Foreground="#6B7280" />
                    <TextBlock Text="{Binding OptimizableProcessCount}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="Memory MB" FontSize="11" Foreground="#6B7280" />
                    <ItemsControl ItemsSource="{Binding GpuMemorySummaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:GpuMemorySummaryViewModel">
                                <Grid ColumnDefinitions="*,Auto" Margin="0 1">
                                    <TextBlock Text="{Binding GpuName}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayMemory}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Margin="8 0 0 0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </UniformGrid>

        <DataGrid x:Name="ProcessGrid"
                  Grid.Row="3"
                  ItemsSource="{Binding Processes}"
                  AutoGenerateColumns="False"
                  SelectionMode="Extended"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  IsReadOnly="False"
                  FontSize="12"
                  GridLinesVisibility="Vertical"
                  HeadersVisibility="Column"
                  RowHeight="26"
                  HorizontalAlignment="Stretch"
                  Margin="0 10 0 0"
                  BorderThickness="1"
                  CornerRadius="0 0 6 6"
                  DoubleTapped="ProcessGrid_DoubleTapped">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Select" Width="72" MinWidth="54">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      IsEnabled="{Binding IsOptimizable}"
                                      HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Process Name" Width="2.2*" MinWidth="120" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ProcessName}"
                                       Margin="18 0 0 0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding ProcessDetailsTooltip}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="GPU" Binding="{Binding GpuAdapters}" Width="220" MinWidth="140" IsReadOnly="True" />
                <DataGridTextColumn Header="Memory" Binding="{Binding DedicatedMemoryMb, StringFormat={}{0:F1}}" Width="95" MinWidth="78" IsReadOnly="True" />
                <DataGridTextColumn Header="Preference" Binding="{Binding CurrentPreference}" Width="110" MinWidth="96" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

    </Grid>

</Window>
